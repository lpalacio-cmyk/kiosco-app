# Copiá este archivo a .streamlit/secrets.toml y completá los valores.
# secrets.toml está en .gitignore: nunca se commitea.

# Contraseña compartida para entrar a la app (decisión 4 de CLAUDE.md).
# Dejar vacía hace que auth.py rechace el arranque con error claro.
APP_PASSWORD = ""

# URL de conexión a la base de datos.
#   Dev local SQLite:  "sqlite:///data/kiosco.db"
#   Prod Supabase (Transaction Pooler, puerto 6543):
#     "postgresql+psycopg2://USER:PASSWORD@HOST:6543/postgres"
DB_URL = "sqlite:///data/kiosco.db"
